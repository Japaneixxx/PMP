# Frontend .env.example

# ========================================
# API BACKEND
# ========================================
VITE_API_URL=http://localhost:8080/api

# ========================================
# INFORMAÇÕES DA APP
# ========================================
VITE_APP_NAME=PMP - Plataforma Médica Paciente
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Plataforma completa para gerenciamento de consultas, exames e prescrições médicas

# ========================================
# FEATURES - Controle de Funcionalidades
# ========================================
VITE_ENABLE_PWA=true
VITE_ENABLE_OFFLINE=true
VITE_ENABLE_NOTIFICATIONS=true

# ========================================
# AMBIENTE
# ========================================
VITE_ENVIRONMENT=development

# ========================================
# LOGGING
# ========================================
VITE_LOG_LEVEL=debug

# ========================================
# ANALYTICS (Opcional)
# ========================================
# VITE_GOOGLE_ANALYTICS_ID=
# VITE_SENTRY_DSN=

# ========================================
# TEMA (Opcional)
# ========================================
# VITE_DEFAULT_THEME=light
# VITE_PRIMARY_COLOR=#007bff
